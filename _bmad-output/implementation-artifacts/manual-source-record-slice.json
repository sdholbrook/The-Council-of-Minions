        "com_extraction_status": "new",
        "com_source_to_work_item_rationale": "Summary-only manual capture can be reviewed later for zero, one, or many proposed Work Items.",
        "com_data_boundary_policy": "summary_allowed"
      }
    ]
  },
  "acceptanceMapping": [
    {
      "acceptanceCriterion": 1,
      "localEvidence": [
        "manualCapture.requiredFields",
        "manualCapture.sampleRecords",
        "manualCapture.workItemCreationOnSave=false",
        "manualCapture.requiresExplicitExtractionStep=true"
      ],
      "tenantEvidenceRequired": "Dataverse Source Record form save in Council Queue after write approval."
    },
    {
      "acceptanceCriterion": 2,
      "localEvidence": [
        "com_databoundarypolicy choice values in manifest",
        "link_only sample without content snapshot",
        "hash_only sample with content hash and without content snapshot",
        "summary_allowed sample with summary snapshot reference"
      ],
      "tenantEvidenceRequired": "Council Queue Source Record form displays data boundary policy and prevents disallowed body capture after write approval."
    }
  ]
}
